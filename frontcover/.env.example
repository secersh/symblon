# Supabase project credentials
# Find these in your Supabase project: Settings → API
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# GitHub App
# Find this in your GitHub App settings (the slug in the install URL)
# In your GitHub App → Settings → "Setup URL (optional)", set to:
#   https://your-domain.com/settings/github/callback
# For local dev: http://localhost:5173/settings/github/callback
PUBLIC_GITHUB_APP_SLUG=symblon-cc
