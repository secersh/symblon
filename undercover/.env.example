# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
AMQP_URL=amqp://guest:guest@localhost:5672/

# ── S3-compatible storage (Supabase Storage) ──────────────────────────────────
# Enable: Supabase Dashboard → Storage → S3 credentials
# Endpoint format: <project-ref>.supabase.co/storage/v1/s3
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=symblon
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Paquetier ─────────────────────────────────────────────────────────────────
S3_PREFIX=events          # Parquet events live under s3://bucket/events/

# ── Registrar ─────────────────────────────────────────────────────────────────
# Supabase Postgres: Dashboard → Project Settings → Database → Connection string (URI)
REGISTRAR_POSTGRES_DSN=postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

S3_AGENTS_PREFIX=agents   # Agent SQL + assets live under s3://bucket/agents/

# ── Overseer ──────────────────────────────────────────────────────────────────
# Can point to a separate Supabase project or a different schema on the same one.
OVERSEER_POSTGRES_DSN=postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

S3_EVENTS_PREFIX=events   # Must match S3_PREFIX used by paquetier
