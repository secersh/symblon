# Copy this file to .env and fill in the values you need.
# Never commit .env to version control.

# ── Cloudflare Tunnel (optional) ─────────────────────────────────────────────
# Used by the `cloudflared` service when running:
#   docker compose --profile tunnel up --build
#
# Leave blank to use a temporary Quick Tunnel (*.trycloudflare.com).
# The assigned URL is printed in the cloudflared container logs.
#
# To use a persistent named tunnel instead:
#  1. Create a tunnel in the Cloudflare Zero Trust dashboard
#     (https://one.dash.cloudflare.com → Networks → Tunnels → Create a tunnel)
#  2. Copy the tunnel token from the "Install connector" step
#  3. Set it here
CLOUDFLARE_TUNNEL_TOKEN=
