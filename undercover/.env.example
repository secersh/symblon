# Copy this file to .env and fill in the values you need.
# Never commit .env to version control.

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
AMQP_URL=amqp://guest:guest@localhost:5672/

# ── Paquetier: storage backend ────────────────────────────────────────────────
# Local disk (default — used when S3_ENDPOINT is not set)
DATA_DIR=/data

# Supabase Storage (S3-compatible) — set all five to enable S3 backend.
# Credentials: Supabase Dashboard → Storage → S3 credentials (enable first)
# Endpoint format: <project-ref>.supabase.co/storage/v1/s3
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=symblon-events
S3_PREFIX=events
S3_ACCESS_KEY=
S3_SECRET_KEY=
